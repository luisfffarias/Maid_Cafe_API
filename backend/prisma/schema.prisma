generator client {
  provider = "prisma-client-js" // Corrigido: o nome correto é prisma-client-js
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  MAID
  ADMIN
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}